# ────────────────────────────────────────────────────────────────────
# AGENTE — Sua Musica Personalizada (server-only secrets)
# Copie pra .env e preencha. NUNCA commite o .env real.
# ────────────────────────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o-mini

# Evolution API (server-side — não exponha a chave no client)
EVOLUTION_API_URL=https://sua-evolution.exemplo.com
EVOLUTION_API_KEY=sua_apikey_evolution

# Variáveis de negócio (substitua se mudar de preço/política)
PRECO_MUSICA=R$ 19,90
PRECO_MUSICA_SITE=R$ 29,90
PRAZO_ENTREGA=em até 2 horas
CHAVE_PIX=andreyurifurtado1@gmail.com
DADOS_RECEBEDOR=Andre Yuri Furtado

# Histórico mantido por conversa (msgs)
MAX_HISTORY=30

# Buffer/debounce de mensagens em rajada (ms). Junta várias msgs seguidas
# do cliente e responde uma vez só. 0 = desliga o buffer.
BUFFER_MS=8000

# ────────────────────────────────────────────────────────────────────
# UI / PÚBLICO (estes podem vazar pro client — sem segredos aqui)
# ────────────────────────────────────────────────────────────────────
VITE_EVOLUTION_API_URL=https://sua-evolution.exemplo.com
VITE_EVOLUTION_API_KEY=apikey_publica_se_quiser_listar_instancias_no_dashboard
